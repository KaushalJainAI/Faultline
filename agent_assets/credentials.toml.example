# Faultline credential config for this project.
#
# Place this file at:  <your-project>/.faultline/credentials.toml
# (copy this file and fill in your values)
#
# IMPORTANT: Never commit the real credentials.toml — keep it in .gitignore.
#            Only this .example file should be committed.
#
# ── auth_type controls how credentials are sent on every authenticated request ──
#
#   bearer   →  POST username+password to login_url → get token →
#                Authorization: Bearer <token>
#
#   api_key  →  Authorization: Bearer is skipped; instead uses:
#                X-API-Key: <token>
#
#   basic    →  No login flow needed. Directly uses username+password:
#                Authorization: Basic base64(<username>:<password>)
#
#   cookie   →  POST username+password to login_url → get token →
#                Cookie: session=<token>
#
#   none     →  No auth header (public API)
#
# ── Login flow (bearer / cookie / api_key) ──────────────────────────────────
#
#   If a role has username+password but no token, Faultline will automatically
#   POST to login_url to exchange credentials for a token. It tries multiple
#   common request body formats (username/password and email/password) and
#   parses common token response fields (token, access_token, access, key, jwt).
#
#   If login_url is not set, or login fails, the agent will pause and ask the
#   operator for a token via HITL (human-in-the-loop prompt).
#
# ── Roles ────────────────────────────────────────────────────────────────────
#
#   Add one [credentials.<role>] section per RBAC role the target exposes.
#   The agent calls get_credential("admin"), get_credential("user"), etc.
#   Resolution order per role:
#     1. token present in file           → use it directly
#     2. username+password + login_url   → auto-login to obtain token
#     3. basic auth                      → encode username:password directly
#     4. HITL prompt to operator
#     5. Mark as unavailable, skip auth-dependent tests

[target]
url               = "http://localhost:8000"
auth_type         = "bearer"               # bearer | api_key | basic | cookie | none
login_url         = "/api/auth/login/"     # POST endpoint that returns a token — remove if not needed
token_refresh_url = "/api/auth/token/refresh/"  # JWT refresh endpoint (simplejwt default)

# ---------------------------------------------------------------------------
# Named credential roles
# ---------------------------------------------------------------------------

# username  — Django username (used for simplejwt / basic auth)
# email     — Account email (used for allauth / dj-rest-auth with ACCOUNT_LOGIN_METHODS={'email'})
#             If the target uses email-based login, fill this in instead of (or alongside) username.
# password  — Account password
# token     — Pre-obtained bearer/API token. Leave blank → Faultline auto-logs in via login_url.

[credentials.default]
username      = ""
email         = ""
password      = ""
token         = ""            # pre-obtained access token (static, use for API keys or long-lived tokens)
refresh_token = ""            # JWT refresh token — Faultline exchanges this for access tokens automatically
                              # Get from browser: DevTools → Application → Cookies → "refresh_token"

[credentials.admin]
username = ""
email    = "admin@example.com"
password = ""
token    = ""

[credentials.user]
username = ""
email    = "testuser@example.com"
password = ""
token    = ""

[credentials.readonly]
username = ""
email    = ""
password = ""
token    = ""
