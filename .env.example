# --- Django Settings ---
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FAULTLINE_API_KEY=

# --- Provider Configuration ---
# Options: openai | openrouter | anthropic | google | nvidia | claude_cli | gemini_cli | codex_cli
FAULTLINE_PROVIDER=openrouter
FAULTLINE_MODEL=google/gemini-2.0-flash-001

# --- API Keys ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# --- Codex CLI (run on a ChatGPT Plus/Pro subscription, no API key) ---
# Set FAULTLINE_PROVIDER=codex_cli above, install the OpenAI Codex CLI,
# then `codex login` (uses your ChatGPT subscription quota).
# FAULTLINE_CODEX_BINARY=codex
# FAULTLINE_CODEX_SANDBOX=read-only
# FAULTLINE_CODEX_CLI_ARGS=--model gpt-5-codex
# When provider is codex_cli, FAULTLINE_MAX_LLM_CALLS auto-defaults to 40
# (Codex concludes in fewer turns). Override that codex-only default with:
# FAULTLINE_CODEX_MAX_LLM_CALLS=40

# --- Path Configuration (Optional) ---
# OPENAI_API_BASE=

# --- Budget & Rate Limits ---
# Leave commented to keep provider-aware defaults (120 for API providers,
# 40 for codex_cli). Setting it explicitly overrides BOTH defaults.
# FAULTLINE_MAX_LLM_CALLS=150
FAULTLINE_MAX_TOOL_CALLS=300
FAULTLINE_MAX_INPUT_TOKENS=200000
FAULTLINE_MAX_OUTPUT_TOKENS=30000
FAULTLINE_TOKEN_BUDGET_DEFAULT=1000000
FAULTLINE_TOKEN_BUDGET_HARD_CAP=2500000
# Optional override for a specific campaign run.
# Keep this <= FAULTLINE_TOKEN_BUDGET_HARD_CAP.
# FAULTLINE_TOKEN_BUDGET=1000000
FAULTLINE_MAX_RPM=36
FAULTLINE_CALL_TIMEOUT=600
# Max independent tool calls executed concurrently within one LLM turn.
FAULTLINE_MAX_PARALLEL_TOOLS=8
FAULTLINE_REASONING_LEVEL=normal
FAULTLINE_CONTEXT_RATIO=0.8

# --- Phase & Context Management ---
FAULTLINE_PHASE_DISCOVERY_CAP=15
FAULTLINE_PHASE_TEST_CAP=50
FAULTLINE_PHASE_CHAOS_CAP=30
FAULTLINE_PHASE_REPORT_CAP=20
FAULTLINE_WRAP_UP_THRESHOLD=0.60
FAULTLINE_TIER2_CYCLES=5
FAULTLINE_SUMMARY_THRESHOLD=5000
FAULTLINE_CONTEXT_RATIO=0.8
FAULTLINE_PLAN_REMINDER_TOKENS=1800
FAULTLINE_TOOL_SCHEMA_RESERVE_TOKENS=18000
FAULTLINE_MEMORY_INJECT_MAX_TOKENS=2500
FAULTLINE_PREFLIGHT_MARGIN_TOKENS=8192
