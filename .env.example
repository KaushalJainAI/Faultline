# --- Django Settings ---
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FAULTLINE_API_KEY=

# --- Provider Configuration ---
# Options: openai | openrouter | anthropic | google | nvidia | claude_cli | gemini_cli | codex_cli
FAULTLINE_PROVIDER=openrouter
FAULTLINE_MODEL=google/gemini-2.0-flash-001

# --- API Keys ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# --- Path Configuration (Optional) ---
# OPENAI_API_BASE=

# --- Budget & Rate Limits ---
FAULTLINE_MAX_LLM_CALLS=150
FAULTLINE_MAX_TOOL_CALLS=300
FAULTLINE_MAX_INPUT_TOKENS=200000
FAULTLINE_MAX_OUTPUT_TOKENS=30000
FAULTLINE_MAX_RPM=36
FAULTLINE_CALL_TIMEOUT=600
FAULTLINE_REASONING_LEVEL=normal
FAULTLINE_CONTEXT_RATIO=0.8

# --- Phase & Context Management ---
FAULTLINE_PHASE_DISCOVERY_CAP=15
FAULTLINE_PHASE_TEST_CAP=50
FAULTLINE_PHASE_CHAOS_CAP=30
FAULTLINE_PHASE_REPORT_CAP=20
FAULTLINE_WRAP_UP_THRESHOLD=0.60
FAULTLINE_TIER2_CYCLES=5
FAULTLINE_SUMMARY_THRESHOLD=5000
FAULTLINE_CONTEXT_RATIO=0.8
